{
  "title": "Flash Sale Overview",
  "uid": "flash-sale-overview",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requests per Second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(flash_sale_requests_total[30s])",
          "legendFormat": "{{method}} {{endpoint}} {{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Current Inventory (Live Stock)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "flash_sale_inventory_current",
          "legendFormat": "Sale {{sale_id}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Orders per Second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(flash_sale_orders_total[30s])",
          "legendFormat": "Sale {{sale_id}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Rate Limited Requests",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(flash_sale_rate_limited_total[30s])",
          "legendFormat": "Rate Limited req/s"
        }
      ]
    },
    {
      "id": 5,
      "title": "P99 Request Latency",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(flash_sale_request_duration_seconds_bucket[30s]))",
          "legendFormat": "P99 {{endpoint}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(flash_sale_requests_total{status_code=~\"4..|5..\"}[30s])",
          "legendFormat": "{{status_code}} {{endpoint}}"
        }
      ]
    }
  ]
}
